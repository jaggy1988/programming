#!/usr/bin/env python3
# xor2ip - XOR two IP addresses (IPv4 or IPv6)
# Usage: xor2ip <ip1> <ip2>

import sys
import ipaddress

def xor_ips(a: str, b: str) -> ipaddress.IPv4Address | ipaddress.IPv6Address:
    ia = ipaddress.ip_address(a)
    ib = ipaddress.ip_address(b)
    print(bin(int(ia))[2:].zfill(32 if ia.version == 4 else 128) + " XOR " + bin(int(ib))[2:].zfill(32 if ib.version == 4 else 128))
    if ia.version != ib.version:
        raise ValueError("IP address versions differ (one IPv4 and one IPv6).")
    xr = int(ia) ^ int(ib)
    # keep width consistent (32 bits for IPv4, 128 for IPv6)
    max_bits = 32 if ia.version == 4 else 128
    xr &= (1 << max_bits) - 1
    return ipaddress.ip_address(xr)

def main(argv):
    if len(argv) != 3:
        print("Usage: xor2ip <ip1> <ip2>", file=sys.stderr)
        return 2
    try:
        res = xor_ips(argv[1], argv[2])
    except ValueError as e:
        print("Error:", e, file=sys.stderr)
        return 1
    # print results: canonical form, integer, hex
    print(str(res))
    print("int:", int(res))
    print("hex:", hex(int(res)))
    print("bin:", bin(int(res))[2:].zfill(32 if res.version == 4 else 128))
    print("bitlength:", int(res).bit_length())
    return 0

if __name__ == "__main__":
    sys.exit(main(sys.argv))